{
  "name": "rianell",
  "private": true,
  "version": "1.46.14",
  "description": "Rianell - health dashboard (rianell.com); PWA webapp, React Native app, and legacy Capacitor shell",
  "workspaces": [
    "apps/*",
    "packages/*",
    "benchmarks"
  ],
  "scripts": {
    "dev": "cd apps/capacitor-app && npm run dev",
    "test:unit": "node --test tests/unit/**/*.test.mjs",
    "typecheck:mobile": "cd apps/rn-app && npm run typecheck",
    "test:mobile": "cd apps/rn-app && npm test",
    "bundle:mobile:prod": "cd apps/rn-app && npx expo export --platform android --platform ios --output-dir dist-expo-prod",
    "build:web:apk": "node apps/pwa-webapp/build-site.mjs --skip-trace",
    "build:react": "cd apps/capacitor-app && npm run build",
    "build": "npm run build:web && npm run build:react",
    "build:apk": "npm run build:web:apk && npm run build:react",
    "build:android": "npm run build:apk && node scripts/prepare-android-assets.mjs && cd apps/capacitor-app && npx @capacitor/assets generate --android --iconBackgroundColor \"#1a1d1e\" --iconBackgroundColorDark \"#0a0a0a\" --splashBackgroundColor \"#1a1d1e\" --splashBackgroundColorDark \"#0a0a0a\" && npx cap sync android",
    "android": "cd apps/capacitor-app && npx cap open android",
    "sync": "cd apps/capacitor-app && npx cap sync",
    "build:web": "node apps/pwa-webapp/build-site.mjs",
    "icons:generate": "node scripts/generate-icon-set.mjs",
    "icons:beta": "node scripts/add-beta-badge-to-icons.mjs",
    "smoke:trace": "node scripts/smoke-function-trace.mjs",
    "parity:android": "node scripts/check-platform-parity.mjs android",
    "parity:ios": "node scripts/check-platform-parity.mjs ios",
    "benchmark": "npm run all --workspace=@rianell/benchmark-runner",
    "benchmark:web": "npm run web --workspace=@rianell/benchmark-runner",
    "benchmark:expo": "npm run expo --workspace=@rianell/benchmark-runner",
    "benchmark:all": "npm run benchmark"
  },
  "devDependencies": {
    "@babel/generator": "^7.26.5",
    "@babel/parser": "^7.26.7",
    "@babel/traverse": "^7.26.7",
    "@babel/types": "^7.26.7",
    "@capacitor/cli": "7.6.1",
    "esbuild": "^0.25.0",
    "sharp": "^0.33.5"
  },
  "overrides": {
    "@capacitor/assets": {
      "@capacitor/cli": "$@capacitor/cli"
    },
    "@tootallnate/once": "^3.0.1",
    "brace-expansion": "^5.0.5",
    "handlebars": "^4.7.9",
    "http-proxy-agent": "^7.0.2",
    "minimatch": "^10.0.3",
    "replace": {
      "minimatch": "^10.0.3"
    },
    "semver": "^7.6.3",
    "send": "^0.19.0",
    "tar": "^7.5.11"
  },
  "engines": {
    "node": ">=20"
  }
}
