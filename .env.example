# Copy to .env and fill in your values. Do not commit .env.

PORT=8080
# Default in app is 127.0.0.1 (loopback only). Use 0.0.0.0 to listen on all interfaces (LAN phones); see SECURITY.md
HOST=127.0.0.1
# Set to 1 only on trusted LANs: allows /api/encryption-key and /api/anonymized-data from non-loopback clients
HEALTH_APP_SENSITIVE_APIS_ON_LAN=

# Supabase (get from https://app.supabase.com/project/_/settings/api)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Encryption key for anonymized data (or create .encryption_key file with one line)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
