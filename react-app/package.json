{
  "name": "rianell-shell",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node copy-webapp.js && vite",
    "build": "node copy-webapp.js --min && vite build",
    "preview": "vite preview",
    "copy-webapp": "node copy-webapp.js",
    "cap:sync": "cap sync android",
    "cap:android": "cap open android",
    "cap:android-assets": "node ../scripts/prepare-android-assets.mjs && npx @capacitor/assets generate --android --iconBackgroundColor \"#1a1d1e\" --iconBackgroundColorDark \"#0a0a0a\" --splashBackgroundColor \"#1a1d1e\" --splashBackgroundColorDark \"#0a0a0a\""
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.4",
    "@capacitor/local-notifications": "^7.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.6.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^7.6.0",
    "@capacitor/ios": "^7.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.0"
  },
  "overrides": {
    "@capacitor/assets": {
      "@capacitor/cli": "$@capacitor/cli"
    },
    "tar": "^7.5.11",
    "replace": {
      "minimatch": "^9.0.5"
    }
  },
  "capacitor": {
    "platforms": ["android", "ios"]
  }
}