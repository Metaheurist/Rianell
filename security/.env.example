# Copy this file to `.env` in this folder and fill in values. Do not commit `.env`.
# Legacy: a `.env` at the repository root is still loaded if `security/.env` is missing.

PORT=8080
# Default in app is 127.0.0.1 (loopback only). Use 0.0.0.0 to listen on all interfaces (LAN phones); see docs/SECURITY.md
HOST=127.0.0.1
# Set to 1 only on trusted LANs: allows /api/encryption-key and /api/anonymized-data from non-loopback clients
HEALTH_APP_SENSITIVE_APIS_ON_LAN=
# Optional: when LAN mode is on, require this exact value in header X-Rianell-LAN-Secret on those API requests
HEALTH_APP_SENSITIVE_APIS_LAN_SECRET=

# Supabase - https://app.supabase.com/project/_/settings/api
SUPABASE_URL=
# Publishable key (public; safe in web builds). If empty, legacy SUPABASE_ANON_KEY is still read.
SUPABASE_PUBLISHABLE_KEY=
# Secret keys → service_role (server only; never in the browser). If empty, legacy SUPABASE_SERVICE_KEY is still read.
SUPABASE_SECRET_KEY=
# Legacy (still supported if the names above are unset):
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=

# Optional: Postgres connection string (Supabase → Settings → Database → URI). Required for auto-reset
# of anonymized_data id sequence after “Wipe Database” unless you deploy a custom exec_sql RPC (this repo
# does not). Wipe still deletes rows without DATABASE_URL.

# DATABASE_URL=

# Encryption key for anonymized data (or create `.encryption_key` in this folder with one line)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
